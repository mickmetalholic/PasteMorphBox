{
  "extends": "@pastemorphbox/config-ts/base",
  "compilerOptions": {
    "incremental": true,
    "target": "es2023",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "types": ["node"],
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo"
  },
  "include": ["next-env.d.ts", "next.config.ts", "postcss.config.mjs", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
